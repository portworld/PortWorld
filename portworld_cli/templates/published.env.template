# PortWorld published-workspace env template.
#
# Minimum runtime setup:
# - choose a realtime provider and set its required key
# - keep VISION_MEMORY_ENABLED=false unless you want a vision provider
# - keep MEMORY_CONSOLIDATION_ENABLED unset unless you want durable-memory consolidation
# - keep REALTIME_TOOLING_ENABLED=false unless you want a search provider

# ----------------------------
# Common Setup (edit first)
# ----------------------------

# Realtime provider selection.
REALTIME_PROVIDER=openai
VISION_MEMORY_ENABLED=false
VISION_MEMORY_PROVIDER=mistral
MEMORY_CONSOLIDATION_ENABLED=
REALTIME_TOOLING_ENABLED=false
REALTIME_WEB_SEARCH_PROVIDER=tavily

# Minimum viable setup: realtime-only
# REALTIME_PROVIDER=openai       -> set OPENAI_API_KEY
# REALTIME_PROVIDER=gemini_live  -> set GEMINI_LIVE_API_KEY
#
# Minimum viable setup: realtime + vision
# set VISION_MEMORY_ENABLED=true and select VISION_MEMORY_PROVIDER
# then set the required key(s) for that provider below
#
# Minimum viable setup: realtime + durable-memory consolidation
# set MEMORY_CONSOLIDATION_ENABLED=true
# select VISION_MEMORY_PROVIDER
# then set the required key(s) for that provider below
#
# Minimum viable setup: realtime + tooling
# set REALTIME_TOOLING_ENABLED=true and set TAVILY_API_KEY

# ----------------------------
# Provider-Scoped Settings
# ----------------------------
# Canonical provider-scoped keys only.
# Legacy aliases (VISION_PROVIDER_*, MISTRAL_*, and AWS_* Bedrock fallbacks)
# are intentionally ignored.

# Realtime provider: openai
OPENAI_API_KEY=
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=ash
REALTIME_INSTRUCTIONS=You are a concise assistant. Keep answers short, clear, and practical.

# Realtime provider: gemini_live
GEMINI_LIVE_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_LIVE_BASE_URL=
GEMINI_LIVE_ENDPOINT=

# Vision providers
# mistral (required key: VISION_MISTRAL_API_KEY)
VISION_MISTRAL_API_KEY=
VISION_MISTRAL_MODEL=ministral-14b-2512
VISION_MISTRAL_BASE_URL=

# nvidia_integrate (required key: VISION_NVIDIA_API_KEY)
VISION_NVIDIA_API_KEY=
VISION_NVIDIA_MODEL=mistralai/ministral-14b-instruct-2512
VISION_NVIDIA_BASE_URL=https://integrate.api.nvidia.com

# openai (required key: VISION_OPENAI_API_KEY)
VISION_OPENAI_API_KEY=
VISION_OPENAI_MODEL=gpt-5.4-nano
VISION_OPENAI_BASE_URL=

# azure_openai (required: VISION_AZURE_OPENAI_API_KEY and VISION_AZURE_OPENAI_ENDPOINT)
VISION_AZURE_OPENAI_API_KEY=
VISION_AZURE_OPENAI_ENDPOINT=
VISION_AZURE_OPENAI_API_VERSION=2024-10-21
VISION_AZURE_OPENAI_DEPLOYMENT=
# Optional fallback when your Azure deployment name matches the model identifier.
VISION_AZURE_OPENAI_MODEL=

# gemini (required key: VISION_GEMINI_API_KEY)
VISION_GEMINI_API_KEY=
VISION_GEMINI_MODEL=gemini-3.1-flash-lite-preview
VISION_GEMINI_BASE_URL=

# claude (required key: VISION_CLAUDE_API_KEY)
VISION_CLAUDE_API_KEY=
VISION_CLAUDE_MODEL=claude-haiku-4-5
VISION_CLAUDE_BASE_URL=

# bedrock (required config: VISION_BEDROCK_REGION; optional AWS credentials)
VISION_BEDROCK_REGION=eu-west-2
VISION_BEDROCK_MODEL=mistral.ministral-3-3b-instruct
VISION_BEDROCK_AWS_ACCESS_KEY_ID=
VISION_BEDROCK_AWS_SECRET_ACCESS_KEY=
VISION_BEDROCK_AWS_SESSION_TOKEN=

# groq (required key: VISION_GROQ_API_KEY)
VISION_GROQ_API_KEY=
VISION_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VISION_GROQ_BASE_URL=

# Search provider: tavily (required key when REALTIME_TOOLING_ENABLED=true)
TAVILY_API_KEY=
TAVILY_BASE_URL=

# Durable-memory consolidation shares the selected vision provider/model.
# When unset, MEMORY_CONSOLIDATION_ENABLED defaults to the current
# VISION_MEMORY_ENABLED value.
MEMORY_CONSOLIDATION_TIMEOUT_MS=30000

# Storage and server basics.
BACKEND_DATA_DIR=backend/var
BACKEND_SQLITE_PATH=
# Storage backend contract.
# Local development keeps the current SQLite/filesystem mode by default.
# Managed Cloud Run deploys set managed + gcs and inject
# BACKEND_DATABASE_URL from Secret Manager.
BACKEND_STORAGE_BACKEND=local
BACKEND_DATABASE_URL=
BACKEND_OBJECT_STORE_PROVIDER=filesystem
# Canonical managed object-store settings.
BACKEND_OBJECT_STORE_NAME=
BACKEND_OBJECT_STORE_ENDPOINT=
BACKEND_OBJECT_STORE_PREFIX=
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
# Extension-system settings.
# Leave blank to disable external extension loading.
# CLI-managed workspaces set these automatically.
PORTWORLD_EXTENSIONS_MANIFEST=
PORTWORLD_EXTENSIONS_PYTHON_PATH=

# Security posture.
# BACKEND_PROFILE=development keeps local defaults.
# BACKEND_PROFILE=production requires:
# - BACKEND_BEARER_TOKEN
BACKEND_PROFILE=development
BACKEND_BEARER_TOKEN=
# Trust forwarded client-IP headers only from these direct peer proxy IPs/CIDRs.
# For reverse-proxy/LB deployments, set this to your proxy IP/CIDR list.
BACKEND_FORWARDED_ALLOW_IPS=127.0.0.1,::1

# ----------------------------
# Advanced Overrides
# ----------------------------

# Transport/runtime tuning.
BACKEND_UPLINK_ACK_EVERY_N_FRAMES=20
REALTIME_INCLUDE_TURN_DETECTION=true
REALTIME_ENABLE_MANUAL_TURN_FALLBACK=true
REALTIME_MANUAL_TURN_FALLBACK_DELAY_MS=900

# Request and retention limits.
BACKEND_MAX_VISION_REQUEST_BYTES=4000000
BACKEND_MAX_VISION_FRAME_BYTES=2500000
BACKEND_SESSION_MEMORY_RETENTION_DAYS=30

# Endpoint rate limits (sliding window).
# Default is false for development profile.
# In production profile, default is true unless explicitly overridden.
BACKEND_ENABLE_IP_RATE_LIMITS=false
BACKEND_RATE_LIMIT_WS_IP_MAX_ATTEMPTS=30
BACKEND_RATE_LIMIT_WS_SESSION_MAX_ATTEMPTS=6
BACKEND_RATE_LIMIT_WS_WINDOW_SECONDS=60
BACKEND_RATE_LIMIT_VISION_IP_MAX_REQUESTS=120
BACKEND_RATE_LIMIT_VISION_SESSION_MAX_REQUESTS=60
BACKEND_RATE_LIMIT_VISION_WINDOW_SECONDS=60
BACKEND_RATE_LIMIT_HTTP_IP_MAX_REQUESTS=30
BACKEND_RATE_LIMIT_HTTP_WINDOW_SECONDS=60

# Realtime-tooling tuning.
REALTIME_TOOL_TIMEOUT_MS=4000
REALTIME_WEB_SEARCH_MAX_RESULTS=3

# Visual-memory tuning.
VISION_SHORT_TERM_WINDOW_SECONDS=30
VISION_MIN_ANALYSIS_GAP_SECONDS=3
VISION_SCENE_CHANGE_HAMMING_THRESHOLD=12
VISION_PROVIDER_MAX_RPS=1
VISION_PROVIDER_TIMEOUT_SECONDS=45
VISION_ANALYSIS_HEARTBEAT_SECONDS=15
VISION_PROVIDER_BACKOFF_INITIAL_SECONDS=5
VISION_PROVIDER_BACKOFF_MAX_SECONDS=60
VISION_DEFERRED_CANDIDATE_TTL_SECONDS=10
VISION_SESSION_ROLLUP_INTERVAL_SECONDS=10
VISION_SESSION_ROLLUP_MIN_ACCEPTED_EVENTS=5

# Debug-only settings.
BACKEND_DEBUG_TRACE_WS_MESSAGES=false
# Keep false for normal self-host operation so raw frames are deleted
# after derived-memory processing.
VISION_DEBUG_RETAIN_RAW_FRAMES=false
