# Port:🌍 minimal runtime configuration
# Required in most setups:
# - MAIN_LLM_API_KEY
# - VOXTRAL_API_KEY (if speech-to-text)
# - NEMOTRON_API_KEY + NEMOTRON_BASE_URL (if video reasoning)
# - ELEVENLABS_API_KEY (if text-to-speech)

APP_NAME=Port:🌍 Open Framework
APP_VERSION=0.1.0
CORS_ORIGINS=*
EDGE_API_KEY=

# Runtime limits
REQUEST_TIMEOUT_S=240
MAX_AUDIO_BYTES=25000000
MAX_IMAGE_BYTES=5000000
MAX_VIDEO_BYTES=50000000

# Main LLM
MAIN_LLM_BASE_URL=https://api.mistral.ai/v1
MAIN_LLM_API_KEY=
MAIN_LLM_CHAT_PATH=/chat/completions
MAIN_LLM_MODEL=mistral-large-latest
MAIN_LLM_TEMPERATURE=0.2
MAIN_LLM_MAX_TOKENS=700
# Values: openai_compat,strands
MAIN_LLM_DRIVER=openai_compat
MAIN_LLM_SYSTEM_PROMPT=You are an intelligent voice assistant for Meta Ray-Ban smart glasses operating in a real-time audio-visual ecosystem. Context: You receive visual analysis from an NVIDIA VLM and voice transcriptions from Voxtral, then generate responses that ElevenLabs converts to speech. Your role: Provide concise, useful, and contextually relevant responses in 1-2 sentences maximum. Priorities: 1. Safety first - immediately flag any urgent situations or hazards 2. Clarity - use simple, direct language suitable for voice 3. Practical utility - focus on actionable information Response guidelines: - Generate only the exact spoken text - no artifacts, introductions, or formatting - Adapt tone to natural, conversational speech patterns - Use available visual context to enhance relevance - For urgent matters, begin with 'Important:' or 'Warning:' - Keep responses brief enough for comfortable listening through glasses speakers

# Voxtral (input voice)
VOXTRAL_BASE_URL=https://api.mistral.ai/v1
VOXTRAL_API_KEY=
VOXTRAL_STT_PATH=/audio/transcriptions
VOXTRAL_STT_MODEL=voxtral-mini-latest
VOXTRAL_LANGUAGE=fr

# Nemotron 12B (input video)
NEMOTRON_BASE_URL=http://127.0.0.1:8000/v1
NEMOTRON_API_KEY=EMPTY
NEMOTRON_CHAT_PATH=/chat/completions
NEMOTRON_MODEL=nvidia/NVIDIA-Nemotron-Nano-12B-v2-VL-BF16
NEMOTRON_TEMPERATURE=0.2
NEMOTRON_MAX_TOKENS=700
NEMOTRON_VIDEO_PROMPT=Describe this video with practical details useful to the main assistant.

# Vision model (optional)
VISION_LLM_BASE_URL=https://api.mistral.ai/v1
VISION_LLM_API_KEY=
VISION_LLM_CHAT_PATH=/chat/completions
VISION_LLM_MODEL=mistral.ministral-3-3b-instruct
VISION_LLM_TEMPERATURE=0.2
VISION_LLM_MAX_TOKENS=350
VISION_SYSTEM_PROMPT=You are the visual analysis component of a smart glasses voice assistant system. Your outputs feed directly into the main LLM that generates spoken responses. You receive real-time images from Meta Ray-Ban smart glasses and must provide: 1. Accurate object detection and scene understanding 2. Clear identification of people, actions, and environmental context 3. Extraction of any visible text that might be relevant 4. Immediate flagging of safety concerns or hazards Your analysis enables the voice assistant to provide context-aware responses. Be precise, objective, and comprehensive in your observations.
VISION_PROMPT=Analyze the image and return valid JSON: description, should_contact, contact_message.

# ElevenLabs (output voice)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_SPEED=1.0
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Tracing
# Values: console,weave,strands
TRACE_BACKENDS=console
