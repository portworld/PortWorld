# PortWorld backend env template.
# Canonical Step 4E self-host path: copy to backend/.env and run docker compose up --build.
#
# Minimum supported runtime modes:
# 1. Realtime-only self-host:
#    - set OPENAI_API_KEY
#    - keep VISION_MEMORY_ENABLED=false
#    - keep REALTIME_TOOLING_ENABLED=false
# 2. Realtime + visual memory:
#    - set OPENAI_API_KEY
#    - set VISION_MEMORY_ENABLED=true
#    - set VISION_PROVIDER_API_KEY for the preferred provider contract
#      or MISTRAL_API_KEY for the legacy default-Mistral fallback
# 3. Realtime + tooling with optional search:
#    - set OPENAI_API_KEY
#    - set REALTIME_TOOLING_ENABLED=true
#    - optionally set TAVILY_API_KEY to enable web_search

# Backend-owned settings
REALTIME_PROVIDER=openai
BACKEND_DATA_DIR=backend/var
BACKEND_SQLITE_PATH=
BACKEND_UPLINK_ACK_EVERY_N_FRAMES=20

# Security / operator settings.
# BACKEND_PROFILE=development keeps local defaults.
# BACKEND_PROFILE=production requires:
# - BACKEND_BEARER_TOKEN
# - explicit CORS_ORIGINS (not *)
# - explicit BACKEND_ALLOWED_HOSTS (not *)
BACKEND_PROFILE=development
# Leave BACKEND_BEARER_TOKEN empty for local-only dev.
# Set it for any shared deployment. Required in production profile.
BACKEND_BEARER_TOKEN=
BACKEND_ALLOWED_HOSTS=*
#
# Request and retention limits.
BACKEND_MAX_VISION_REQUEST_BYTES=4000000
BACKEND_MAX_VISION_FRAME_BYTES=2500000
BACKEND_SESSION_MEMORY_RETENTION_DAYS=30

# Endpoint rate limits (sliding window)
# Default is false for development profile.
# In production profile, default is true unless explicitly overridden.
BACKEND_ENABLE_IP_RATE_LIMITS=false
BACKEND_RATE_LIMIT_WS_IP_MAX_ATTEMPTS=30
BACKEND_RATE_LIMIT_WS_SESSION_MAX_ATTEMPTS=6
BACKEND_RATE_LIMIT_WS_WINDOW_SECONDS=60
BACKEND_RATE_LIMIT_VISION_IP_MAX_REQUESTS=120
BACKEND_RATE_LIMIT_VISION_SESSION_MAX_REQUESTS=60
BACKEND_RATE_LIMIT_VISION_WINDOW_SECONDS=60

# Compatibility-only path; not used by the active iPhone runtime.
BACKEND_ALLOW_TEXT_AUDIO_FALLBACK=false
# Devtools-only probe protocol. Keep disabled for normal app traffic.
BACKEND_ENABLE_DEVTOOLS_PROTOCOL=false

# Debug-only settings.
BACKEND_DEBUG_DUMP_INPUT_AUDIO=false
BACKEND_DEBUG_DUMP_INPUT_AUDIO_DIR=backend/var/debug_audio
BACKEND_DEBUG_MOCK_CAPTURE_MODE=false
BACKEND_DEBUG_TRACE_WS_MESSAGES=false

# Visual-memory settings.
VISION_MEMORY_ENABLED=false
VISION_MEMORY_PROVIDER=mistral
VISION_MEMORY_MODEL=ministral-3b-2512

# Preferred visual-memory provider credentials.
# Required only when VISION_MEMORY_ENABLED=true, unless using the legacy MISTRAL_* fallback below.
VISION_PROVIDER_API_KEY=
# Optional override for OpenAI-compatible /v1/chat/completions backends.
VISION_PROVIDER_BASE_URL=
VISION_SHORT_TERM_WINDOW_SECONDS=30
VISION_MIN_ANALYSIS_GAP_SECONDS=3
VISION_SCENE_CHANGE_HAMMING_THRESHOLD=12
VISION_PROVIDER_MAX_RPS=1
VISION_ANALYSIS_HEARTBEAT_SECONDS=15
VISION_PROVIDER_BACKOFF_INITIAL_SECONDS=5
VISION_PROVIDER_BACKOFF_MAX_SECONDS=60
VISION_DEFERRED_CANDIDATE_TTL_SECONDS=10
VISION_SESSION_ROLLUP_INTERVAL_SECONDS=10
VISION_SESSION_ROLLUP_MIN_ACCEPTED_EVENTS=5

# Debug-only. Keep false for normal self-host operation so raw frames are deleted
# after derived-memory processing.
VISION_DEBUG_RETAIN_RAW_FRAMES=false

# Realtime-tooling settings.
REALTIME_TOOLING_ENABLED=false
REALTIME_TOOL_TIMEOUT_MS=4000
REALTIME_WEB_SEARCH_PROVIDER=tavily
REALTIME_WEB_SEARCH_MAX_RESULTS=3

# Realtime provider settings.
# Required at runtime only when a websocket session needs OpenAI.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=ash
OPENAI_REALTIME_INSTRUCTIONS=You are a concise assistant. Keep answers short, clear, and practical.
# Optional override; app default is enabled.
OPENAI_REALTIME_INCLUDE_TURN_DETECTION=true
OPENAI_REALTIME_ENABLE_MANUAL_TURN_FALLBACK=true
OPENAI_REALTIME_MANUAL_TURN_FALLBACK_DELAY_MS=900

# Legacy default-Mistral fallback.
# Use these only when VISION_MEMORY_ENABLED=true and you are not setting
# VISION_PROVIDER_API_KEY / VISION_PROVIDER_BASE_URL above.
MISTRAL_API_KEY=
MISTRAL_BASE_URL=

# Optional realtime search provider.
# Enables the Step 4C web_search tool only when REALTIME_TOOLING_ENABLED=true.
TAVILY_API_KEY=
TAVILY_BASE_URL=

# Network / server settings.
# Optional TLS trust bundle for environments with missing system cert roots.
# Example: SSL_CERT_FILE=/path/to/cacert.pem (or certifi.where()).
SSL_CERT_FILE=
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
# Local-dev default only. Set explicit origins outside local-only development.
CORS_ORIGINS=*
