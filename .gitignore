# ============================================================================
#                            PortWorld — .gitignore
# ============================================================================
# Covers: Python backend, iOS/Swift (Xcode + SPM), macOS, editors & IDEs


# ──────────────────────────────────────────────────────────────────────────────
#  macOS
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?


# ──────────────────────────────────────────────────────────────────────────────
#  Python
# ──────────────────────────────────────────────────────────────────────────────

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
*.whl
*.tar.gz
sdist/
uv.lock

# Install logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.coverage
.coverage.*
.tox/
.nox/
.pytest_cache/
*.cover
*.py,cover
coverage.xml
nosetests.xml

# Type checkers
.mypy_cache/
.pytype/
.pyre/

# Jupyter Notebook
.ipynb_checkpoints

# Celery
celerybeat-schedule
celerybeat.pid

# Run logs (framework-specific)
run_logs/


# ──────────────────────────────────────────────────────────────────────────────
#  Environment / Secrets
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key


# ──────────────────────────────────────────────────────────────────────────────
#  Xcode / iOS
# ──────────────────────────────────────────────────────────────────────────────

# Build configuration secrets (only the committed template is allowed)
Config/*.xcconfig
IOS/Config/*.xcconfig
!IOS/Config/Config.xcconfig.template

# User-specific Xcode files
xcuserdata/
*.xcuserstate
xcschememanagement.plist
*.xccheckout

# Build products
DerivedData/
build/
*.ipa
*.dSYM.zip
*.dSYM

# Xcode workspaces (auto-regenerated by SPM)
*.xcworkspace/xcuserdata/

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# Archives
*.xcarchive

# Tests
tmp/
__Snapshots__/
tests_archived/

# ──────────────────────────────────────────────────────────────────────────────
#  Swift Package Manager
# ──────────────────────────────────────────────────────────────────────────────
.build/
Packages/
Package.pins
Package.resolved
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved


# ──────────────────────────────────────────────────────────────────────────────
#  CocoaPods (if adopted later)
# ──────────────────────────────────────────────────────────────────────────────
Pods/
*.xcworkspace


# ──────────────────────────────────────────────────────────────────────────────
#  Editors & IDEs
# ──────────────────────────────────────────────────────────────────────────────

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, AppCode, etc.)
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# Emacs
\#*\#
*.elc
auto-save-list/


# ──────────────────────────────────────────────────────────────────────────────
#  Miscellaneous
# ──────────────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
*.rej
*.patch
Thumbs.db
ehthumbs.db
Desktop.ini


# ──────────────────────────────────────────────────────────────────────────────
#  Project-specific
# ──────────────────────────────────────────────────────────────────────────────
realtime_*.md
priority_*.md
TEMPLATE_PROMPT.md
26*/
cleanup/
issues/
debug_audio/
backend/var/
.cursor/
.portworld/
docs/archived/
